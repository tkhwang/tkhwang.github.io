---
interface Props {
  url: string;
  title: string;
  pubDate: Date;
  description?: string;
  tags?: string[];
  variant?: "default" | "editorial";
}

const { url, title, pubDate, variant = "default" } = Astro.props;

const yyyy = pubDate.getFullYear();
const mm = String(pubDate.getMonth() + 1).padStart(2, '0');
const dd = String(pubDate.getDate()).padStart(2, '0');
const dateStr = `${yyyy}-${mm}-${dd}`;
---

<li class:list={["post-item", variant === "editorial" && "post-item-editorial"]}>
  <a href={url} class:list={["post-link", variant === "editorial" && "post-link-editorial"]}>
    <span class="post-title">{title}</span>
    {variant === "editorial" ? <span class="post-divider" aria-hidden="true"></span> : null}
    <span class="post-date">{dateStr}</span>
  </a>
</li>

<style>
  .post-item {
    padding: 0.35rem 0;
    list-style: none;
  }

  .post-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    color: inherit;
    text-decoration: none;
  }

  .post-link:hover .post-title,
  .post-link:focus .post-title {
    text-decoration: underline;
  }

  .post-title {
    font-weight: 700;
  }

  .post-divider {
    flex: 1 1 auto;
    min-width: 1.5rem;
    border-bottom: 1px dotted rgba(15, 23, 42, 0.18);
    transform: translateY(-0.08rem);
  }

  .post-date {
    flex-shrink: 0;
    font-size: 0.875rem;
    color: var(--pico-muted-color);
    font-variant-numeric: tabular-nums;
  }

  .post-item-editorial {
    padding: 0;
  }

  .post-link-editorial {
    align-items: center;
    gap: 0.75rem;
    padding: 0.42rem 0;
  }

  .post-link-editorial:hover .post-title,
  .post-link-editorial:focus .post-title {
    text-decoration: none;
    color: #111827;
  }

  .post-link-editorial .post-title {
    font-size: 0.92rem;
    font-weight: 560;
    line-height: 1.18;
    letter-spacing: -0.01em;
  }

  .post-link-editorial .post-date {
    font-size: 0.72rem;
    font-weight: 560;
    color: #6b7280;
    letter-spacing: 0.01em;
  }

  @media (max-width: 720px) {
    .post-link-editorial {
      display: grid;
      grid-template-columns: 1fr auto;
      grid-template-areas:
        "title title"
        "date date";
      gap: 0.18rem 0.5rem;
      align-items: start;
      padding: 0.42rem 0;
    }

    .post-link-editorial .post-title {
      grid-area: title;
      font-size: 0.9rem;
    }

    .post-link-editorial .post-divider {
      display: none;
    }

    .post-link-editorial .post-date {
      grid-area: date;
      justify-self: start;
      font-size: 0.7rem;
    }
  }
</style>
