---
import BaseLayout from "@layouts/BaseLayout.astro";
import NavWrapper from "@components/NavigationWrapper.astro";
import Heading from "@components/Heading.astro";
import Featured from "@components/Featured.astro";
import RecentProjects from "@components/RecentProjects.astro";
import WorkExperiences from "@components/WorkExperiences.astro";
import DetailsQuote from "@components/DetailsQuote";

const pageTitle: string = "Where Code Meets Design";
---

<BaseLayout pageTitle={pageTitle}>
  <header>
    <NavWrapper />
  </header>
  <hr />
  <main class="container home">
    <section>
      <hgroup>
        <h1>{pageTitle}</h1>
      </hgroup>
      <p>
        코드와 디자인이 만나는 지점에서, 더 나은 소프트웨어를 만들기 위한 고민과 통찰을 기록합니다. <br />
        기술과 디자인, 두 세계의 경계에서 얻은 개발 이야기.
      </p>
        <span class="intro-muted">
          TDD, Clean | Hexagonal architecture, CQRS, Event Sourcing, Design pattern
        </span>
        <br />
        <span class="intro-muted">
          AI | RAG, Agent, ...
        </span>        
    </section>
    <section>
      <div class="section-divider">
        <div class="section-divider__title">
          <span aria-hidden="true">📌</span>
          <Heading
            title="추천 글"
            heading="3"
          />
        </div>
        <div class="section-divider__line" aria-hidden="true"></div>
        <a class="section-divider__link" href="/featured/">전체 추천 글 보기</a>
      </div>
      <Featured />
    </section>
    <section class="blog-link-section">
      <a href="/blog/" class="blog-link">전체 글 보기 →</a>
    </section>
    <!-- <hr />
    <section>
      <hgroup>
        <Heading title="Recent projects" heading="3" description="" />
      </hgroup>
      <RecentProjects />
      <p>
        <small>
          For my featured projects, please visit my
          <a href="https://www.github.com/san-ghun">Github</a>
        </small>
      </p>
    </section> -->
  </main>
</BaseLayout>

<style>
  .intro-muted {
    color: var(--color-text-muted);
    font-weight: 500;
  }
 
  main.home {
    max-width: min(800px, 94vw);
    padding-inline: 1rem;
    font-size: 0.9375rem;
  }

  main.home h1 {
    font-size: clamp(1.45rem, 1.9vw, 1.75rem);
    margin-bottom: 0.25rem;
  }

  main.home p {
    font-size: 0.9375rem;
    line-height: 1.6;
    margin-bottom: 0.6rem;
  }

  main.home .intro-muted {
    font-size: 0.85rem;
  }

  main.home section + section {
    margin-top: 1.75rem;
  }

  .section-divider {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 1.75rem 0 1rem;
  }

  .section-divider__title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .section-divider__title span {
    font-size: 1.1rem;
  }

  .section-divider__title :global(h3) {
    margin: 0;
    font-weight: 700;
  }

  .section-divider__line {
    flex: 1;
    min-width: 120px;
    height: 1px;
    background-color: var(--color-divider);
  }

  .section-divider__link {
    font-size: 0.85rem;
    text-transform: none;
    text-decoration: none;
    color: var(--color-text-muted);
    font-weight: 600;
  }

  .section-divider__link:hover,
  .section-divider__link:focus {
    color: inherit;
    text-decoration: underline;
  }

  .blog-link-section {
    text-align: center;
    margin-top: 2rem;
  }

  .blog-link {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .blog-link:hover,
  .blog-link:focus {
    color: inherit;
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    main.home {
      padding-inline: 0.75rem;
      font-size: 0.9rem;
    }

    main.home h1 {
      font-size: 1.45rem;
    }

    .section-divider {
      gap: 0.5rem;
    }

    .section-divider__line {
      display: none;
    }

    .section-divider__link {
      margin-left: auto;
    }
  }
</style>
