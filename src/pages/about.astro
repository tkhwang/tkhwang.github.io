---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Ava from '@src/assets/img/ava.jpg';
import Prose from '../components/Prose.astro';
---

<BaseLayout title='About Me' description='Lorem ipsum dolor sit amet'>
	<div class='container'>
		<main class='prose text-lg dark:prose-invert'>
			<article>
				<div class='w-full md:flex md:items-center gap-16 mb-10'>
					<div class='text-pretty leading-9'>
						<h1 class='text-4xl font-bold mb-4'>Hi There 👋, tkHWANG Here!</h1>
						<Prose>
							<div class='text-lg'>
								<p>
									I am a Front-end Engineer from Indonesia. I love sharing what i know on <a href='https://devaradise.com' target='_blank'
										>devaradise.com</a
									>, and sometime i also share freebies like this. I'm also active on <a href='https://dev.to/syakirurahman' target='_blank'
										>dev.to</a
									> and <a href='https://x.com/syakirurahman' target='_blank'>twitter</a>.
								</p>
							</div>
						</Prose>
					</div>
					<Image
						src='https://1.gravatar.com/avatar/442a1f9fb6f731f671d655575ebba466e1e0c4d9d0ea369c3fe7460b02cdb72e'
						alt='Muhammad Syakirurohman'
						width={300}
						height={300}
						class='rounded-3xl rotate-3 mx-4 md:mx-0'
					/>
				</div>
			</article>
		</main>
	</div>
</BaseLayout>
